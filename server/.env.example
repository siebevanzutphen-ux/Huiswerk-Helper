# ---- Kopieer dit bestand naar ".env" en vul je eigen waarden in ----

# Jouw GEHEIME Anthropic API-sleutel. Staat ALLEEN hier op de server, nooit in de website.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Op welke poort de server draait (achter je reverse proxy / HTTPS).
PORT=8787

# De website-adres(sen) die de server mogen aanroepen. Komma-gescheiden.
# Bijv: https://huiswerkhelper.nl,https://www.huiswerkhelper.nl
# Tijdens lokaal testen mag je ook http://localhost:5500 toevoegen.
ALLOWED_ORIGIN=https://jouwdomein.nl

# Een lang, geheim wachtwoord dat JIJ gebruikt om toegangscodes aan te maken/beheren.
# Verzin iets willekeurigs en lang (bijv. 40 tekens).
ADMIN_TOKEN=verzin-hier-een-heel-lang-geheim-wachtwoord

# Standaard maandlimiet per gebruiker (aantal AI-verzoeken). Beschermt je portemonnee.
# 0 = onbeperkt. Je kunt per code een eigen limiet zetten.
DEFAULT_MONTHLY_LIMIT=1500
