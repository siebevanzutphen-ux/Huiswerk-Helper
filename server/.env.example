# ---- Kopieer dit bestand naar ".env" en vul je eigen waarden in ----

# Jouw GEHEIME Anthropic API-sleutel. Staat ALLEEN hier op de server, nooit in de website.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Op welke poort de server draait (achter je reverse proxy / HTTPS).
PORT=8787

# De website-adres(sen) die de server mogen aanroepen. Komma-gescheiden.
# Bijv: https://huiswerkhelper.nl,https://www.huiswerkhelper.nl
# Tijdens lokaal testen mag je ook http://localhost:5500 toevoegen.
ALLOWED_ORIGIN=https://jouwdomein.nl

# Een lang, geheim wachtwoord dat JIJ gebruikt om toegangscodes aan te maken/beheren.
# Verzin iets willekeurigs en lang (bijv. 40 tekens).
ADMIN_TOKEN=verzin-hier-een-heel-lang-geheim-wachtwoord

# Standaard maandlimiet per gebruiker (aantal AI-verzoeken). Beschermt je portemonnee.
# 0 = onbeperkt. Je kunt per code een eigen limiet zetten.
DEFAULT_MONTHLY_LIMIT=1500

# ---- Alarm (optioneel maar aangeraden) ----
# Plak hier een webhook-URL; je krijgt dan een seintje bij verdachte dingen
# (brute-force op codes, gedeelde codes, foute admin-login, maandlimiet bereikt).
# Werkt met een Discord- of Slack-webhook. Leeg = alleen in het logboek (events.log).
ALERT_WEBHOOK_URL=

# ---- Cloudflare origin-lock (optioneel maar aangeraden) ----
# Verzin een lang geheim. Zet in Cloudflare een "Transform Rule" die bij elk verzoek
# de header  X-Origin-Secret: <ditzelfde geheim>  toevoegt. De server weigert dan
# alle verkeer dat NIET via Cloudflare binnenkomt (verbergt je thuis-IP). Zie CLOUDFLARE.md.
CLOUDFLARE_SECRET=

# ---- Gedeelde-code-detectie ----
SHARE_IP_LIMIT=4          # meer dan zoveel verschillende apparaten per code per 24u = waarschuwing
SHARE_HARD_BLOCK=0        # 1 = ook echt blokkeren (standaard 0: alleen waarschuwen)
BRUTE_LIMIT=12            # zoveel foute codes vanaf één IP in 10 min = waarschuwing
